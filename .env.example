# ARIA Environment Variables
# Copy this to .env and fill in your values

# LLM Backend (ollama or openai)
ARIA_LLM_BACKEND=ollama
ARIA_LLM_BASE_URL=http://localhost:11434

# Ollama model (default: qwen2:7b)
ARIA_OLLAMA_MODEL=qwen2:7b

# OpenAI API key (only needed if using openai backend)
# OPENAI_API_KEY=sk-...

# OpenAI model (default: gpt-4o)
ARIA_OPENAI_MODEL=gpt-4o

# Embedding model (default: all-MiniLM-L6-v2)
ARIA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Literature search (for aria_search and aria_full modes)
ARIA_SEARCH_EMAIL=researcher@example.com